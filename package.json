{
	"name": "vanguard-cli",
	"version": "0.1.17",
	"description": "Vanguard - AI-driven development framework with agent personas for Claude Code",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"bin": {
		"vanguard": "./dist/presentation/cli/index.js",
		"vanguard-cli": "./dist/presentation/cli/index.js"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": ["dist", "stacks", "architectures", "templates"],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"start": "node dist/presentation/cli/index.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "vitest run --config vitest.e2e.config.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"check": "npm run typecheck && npm run lint && npm run test",
		"prepublishOnly": "npm run check && npm run build"
	},
	"dependencies": {
		"@clack/prompts": "^0.8.2",
		"cli-progress": "^3.12.0",
		"commander": "^13.0.0",
		"fs-extra": "^11.2.0",
		"glob": "^11.0.0",
		"gradient-string": "^3.0.0",
		"listr2": "^8.2.5",
		"open": "^10.1.0",
		"ora": "^8.1.1",
		"picocolors": "^1.1.1",
		"yaml": "^2.6.1",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/cli-progress": "^3.11.6",
		"@types/fs-extra": "^11.0.4",
		"@types/gradient-string": "^1.1.6",
		"@types/node": "^22.10.5",
		"@vitest/coverage-v8": "^2.1.8",
		"memfs": "^4.14.1",
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"keywords": [
		"cli",
		"ai",
		"development",
		"specification",
		"claude",
		"architecture",
		"ddd",
		"vanguard"
	],
	"author": "Samid Zafar",
	"license": "MIT"
}
